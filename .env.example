# ─────────────────────────────────────────────────────────────────────────────
# theeyebeta — environment variables template
# Copy to .env and fill in real values. Never commit .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=theeyebeta
POSTGRES_DB=theeyebeta
POSTGRES_PASSWORD=changeme_postgres

# ── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=changeme_minio_secret

# ── Grafana ──────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=changeme_grafana

# Alertmanager notification settings.
SMTP_HOST=localhost
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=alerts@theeyebeta.local
ALERT_EMAIL_TO=ops@theeyebeta.local
# Optional: uncomment and wire the Slack receiver in infra/alertmanager/alertmanager.yml.
# SLACK_WEBHOOK_URL=

# ── Application services (add as services are created) ───────────────────────
# DATABASE_URL=postgresql+asyncpg://theeyebeta:changeme_postgres@localhost:5432/theeyebeta
# REDIS_URL=redis://127.0.0.1:6379/0
# REDIS_OPS_URL=redis://127.0.0.1:6379/0   # admin-service cross-service ops (OMS halt, etc.)
# admin-service overrides REDIS_URL to /1 for auth-token isolation.
# NATS_URL=nats://localhost:4222
# MINIO_ENDPOINT=localhost:9000
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# ── Data ingestion ───────────────────────────────────────────────────────────
FRED_API_KEY=
INGEST_DATABASE_URL=postgresql://tb_app:tb_app_CHANGE_ME@127.0.0.1:5432/theeyebeta
MINIO_SNAPSHOT_BUCKET=theeyebeta-snapshots
APCA_API_KEY_ID=
APCA_API_SECRET_KEY=
# Data-ingestion Basic Auth only. Admin-service login is DB-backed; these values
# must not be used as a MASTER_ADMIN bootstrap credential.
ADMIN_USERNAME=admin
# Generate: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_BCRYPT=

# ── LLM gateway (LiteLLM proxy, port 7020) ───────────────────────────────────
# Master key must start with sk- (LiteLLM requirement).
LITELLM_MASTER_KEY=sk-theeyebeta-master-dev-change-me
LITELLM_DB_PASSWORD=changeme_litellm
# Run: LITELLM_DB_PASSWORD=... make db-migrate  (applies 0012_litellm_db)
# LITELLM_DATABASE_URL=postgresql://litellm:changeme_litellm@127.0.0.1:5432/litellm
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# Populated by services/llm_gateway/scripts/provision_virtual_keys.py → sops prod secrets
# LITELLM_KEY_AGENT_RUNTIME_EXECUTORS=
# LITELLM_KEY_RND_AGENT=
# LITELLM_KEY_GUARD_SERVICE_CLASSIFIER=
# Guard service (constitution enforcement)
# GUARD_SERVICE_HTTP_URL=http://127.0.0.1:8005
# GUARD_SERVICE_GRPC_TARGET=127.0.0.1:7040
# GUARD_SERVICE_GRPC_HOST=127.0.0.1
# GUARD_SERVICE_GRPC_PORT=7040
# GUARD_DISABLE_CREATIVE_CLASSIFIER=1
# LITELLM_KEY_EMBEDDINGS=

# ── Admin service (port 7200, JWT RS256) ─────────────────────────────────────
# ADMIN_DATABASE_URL=postgresql://theeyebeta:changeme_postgres@127.0.0.1:5432/theeyebeta
# ADMIN_SERVICE_HOST=0.0.0.0
# ADMIN_SERVICE_PORT=7200
# ADMIN_CORS_CLOUDFLARE_ORIGIN=https://admin.theeyebeta.store
# Data API (sibling TheEyeBetaDataAPI repo, port 7000). TheEyeBetaProd uses the
# dataapiprod Cloudflare hostname by default so bridge calls are visible in the
# same edge/debug path used by external clients. Use loopback only for isolated
# on-host troubleshooting.
# ADMIN_DATAAPI_URL=https://dataapiprod.theeyebeta.store
# ADMIN_DATAAPI_URL=http://127.0.0.1:7000
# ADMIN_DATAAPI_CLIENT_ID=
# ADMIN_DATAAPI_CLIENT_SECRET=
# Public tunnel URL for scripts/verify_dataapi_tunnel.sh (default: dataapiprod hostname).
# DATAAPI_TUNNEL_URL=https://dataapiprod.theeyebeta.store
# ADMIN_CORS_TAILSCALE_ORIGIN=http://100.64.0.1:7200
# ADMIN_COOKIE_SECURE=0
# JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----
# JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# MASTER_ADMIN_TOTP_SECRET=  # real TOTP seed lives only in .env / sops secrets
# AUDIT_SERVICE_URL=http://127.0.0.1:7110
# BACKTEST_ENGINE_URL=http://127.0.0.1:7100
# ADMIN_REPO_ROOT=/opt/theeyebeta  # repo root used to resolve agent constitution_path
# Dashboard (P-FE-dashboard)
# ADMIN_GRAFANA_OVERVIEW_URL=http://grafana:3000/d/overview?orgId=1&kiosk=tv&theme=light
# ADMIN_DAILY_BACKTEST_STRATEGY_ID=
# ADMIN_DAILY_BACKTEST_DAYS=30
# ADMIN_DAILY_BACKTEST_UNIVERSE=
# ADMIN_AUDIT_VERIFY_HOURS=24
# ADMIN_AUDIT_PAGE_LIMIT=50

# ── R&D agent (port 7120, tb_rnd_readonly) ───────────────────────────────────
# RND_DATABASE_URL=postgresql://tb_rnd_readonly:tb_rnd_readonly_test@127.0.0.1:5432/theeyebeta
# RND_AGENT_HOST=127.0.0.1
# RND_AGENT_PORT=7120
# RND_DRY_RUN=1
# RND_RUN_CRON_HOUR=9
# RND_DIGEST_CRON_HOUR=10
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=rnd@theeyebeta.local
# SMTP_TO=ops@theeyebeta.local

# ── Agent runtime (port 8004) ────────────────────────────────────────────────
# AGENT_RUNTIME_HOST=127.0.0.1
# AGENT_RUNTIME_PORT=8004
# AGENT_RUNTIME_URL=http://127.0.0.1:8004
# LITELLM_PROXY_URL=http://127.0.0.1:4000
# LITELLM_KEY_AGENT_RUNTIME_EXECUTORS=  # provision via services/llm_gateway/scripts/provision_virtual_keys.py
# GUARD_SERVICE_GRPC_TARGET=127.0.0.1:7040
# GUARD_SERVICE_HTTP_URL=http://127.0.0.1:8005

# ── Master orchestrator (port 7050) ───────────────────────────────────────────
# MASTER_ORCHESTRATOR_HOST=127.0.0.1
# MASTER_ORCHESTRATOR_PORT=7050
# AGENT_RUNTIME_URL=http://127.0.0.1:8004
# DEFAULT_PORTFOLIO_ID=
# LITELLM_KEY_MASTER_ORCHESTRATOR=
# RISK_SERVICE_URL=http://127.0.0.1:8007
# COMPLIANCE_SERVICE_URL=http://127.0.0.1:8008
# MO_DEFAULT_ORDER_QTY=100

# ── Risk service (gRPC 7060 / HTTP 8007) ─────────────────────────────────────
# Writer for theeyebeta.risk_metrics. Seed book: uv run python db/seeds/seed_paper_risk_portfolio.py
RISK_SERVICE_URL=http://127.0.0.1:8007
RISK_SERVICE_GRPC_HOST=127.0.0.1
RISK_SERVICE_GRPC_PORT=7060
RISK_SERVICE_HTTP_HOST=127.0.0.1
RISK_SERVICE_HTTP_PORT=8007
DEFAULT_PORTFOLIO_ID=b20e8400-e29b-41d4-a716-446655440002
RISK_METRICS_PORTFOLIO_IDS=b20e8400-e29b-41d4-a716-446655440002
RISK_METRICS_INTERVAL_SECONDS=300

# ── OMS (port 7080) ───────────────────────────────────────────────────────────
# OMS_HOST=127.0.0.1
# OMS_PORT=7080
# OMS_SERVICE_URL=http://127.0.0.1:7080
# BROKER_ADAPTER_URL=http://127.0.0.1:7090

# ── Compliance service (gRPC 7070 / HTTP 8008) ────────────────────────────────
# COMPLIANCE_SERVICE_URL=http://127.0.0.1:8008

# ── Broker adapter Alpaca (port 7090, paper default) ──────────────────────────
BROKER_MODE=paper
BROKER_ADAPTER_HOST=127.0.0.1
BROKER_ADAPTER_PORT=7090
# Paper-trading credentials — generate at https://app.alpaca.markets (Paper → API Keys)
ALPACA_API_KEY_PAPER=<your-paper-api-key>
ALPACA_API_SECRET_PAPER=<your-paper-api-secret>
# Paper account IDs (Alpaca app → Account Management → each sub-account)
ALPACA_PAPER_ACCOUNT_ID=<default-paper-account-id>
ALPACA_PAPER_NYSE_ACCOUNT_ID=<nyse-paper-account-id>
ALPACA_PAPER_NASDAQ_ACCOUNT_ID=<nasdaq-paper-account-id>
# alpaca-py selects the correct endpoint automatically when BROKER_MODE=paper.
# The var below is informational only (not read by any service):
ALPACA_BASE_URL=https://paper-api.alpaca.markets/v2
# Legacy data-ingestion aliases (also accepted as fallback by the broker):
# APCA_API_KEY_ID=<same-as-ALPACA_API_KEY_PAPER>
# APCA_API_SECRET_KEY=<same-as-ALPACA_API_SECRET_PAPER>
