# Admin-service local dev — copy to .env and fill secrets. Never commit .env.
# See TheEyeBetaAdminFrontend/README.md for laptop startup steps.

ADMIN_SERVICE_HOST=127.0.0.1
ADMIN_SERVICE_PORT=7200
ADMIN_FRONTEND_ROOT=C:\Repos\TheEyeBeta2025\TheEyeBetaAdminFrontend

ADMIN_USERNAME=admin
# Generate: python -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_BCRYPT=

# Generate: python scripts/generate_admin_jwt_keys.py (from TheEyeProd repo root)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Laptop: Tailscale Postgres. Mac server: postgresql://...@127.0.0.1:5432/...
ADMIN_DATABASE_URL=postgresql://tb_app:CHANGE_ME@the-eye-beta-server:5432/TheEyeBeta2025Live
NATS_URL=nats://127.0.0.1:4222
REDIS_URL=redis://127.0.0.1:6379/1

EDGE_MODE=local
WORKERS_MODE=local
SERVICES_MODE=local
ADMIN_CORS_TAILSCALE_ORIGIN=http://127.0.0.1:7200
ADMIN_COOKIE_SECURE=0

# Data API bridge — Mac server: ADMIN_DATAAPI_URL=http://127.0.0.1:7000
# Laptop (no local :7000): use tunnel URL for both fields below
ADMIN_DATAAPI_URL=https://dataapiprod.theeyebeta.store
DATAAPI_TUNNEL_URL=https://dataapiprod.theeyebeta.store
ADMIN_DATAAPI_CLIENT_ID=theeyebeta-prod-admin
ADMIN_DATAAPI_CLIENT_SECRET=
ADMIN_DATAAPI_SCOPES=admin:*,admin:read,admin:write,market:read,portfolio:read,symbols:read,trades:read,trades:write
# Windows dev laptops hitting Cloudflare tunnel may need:
# ADMIN_DATAAPI_VERIFY_SSL=false
# Comma-separated symbols on terminal home (/admin/):
# ADMIN_TERMINAL_WATCHLIST=AAPL,MSFT,NVDA,GOOGL,AMZN,TSLA,SPY,QQQ
