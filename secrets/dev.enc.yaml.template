# theeyebeta — dev secrets template (plaintext, committed to git)
#
# Usage:
#   cp secrets/dev.enc.yaml.template secrets/dev.enc.yaml.plain
#   # edit dev.enc.yaml.plain — fill in real dev values
#   sops --encrypt --input-type dotenv --output-type yaml \
#        secrets/dev.enc.yaml.plain > secrets/dev.enc.yaml
#   rm secrets/dev.enc.yaml.plain
#   git add secrets/dev.enc.yaml
#
# Format: KEY=VALUE (dotenv). sops encrypts each value individually.
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME

# ── Redis ─────────────────────────────────────────────────────────────────────
# reserved — not wired yet; compose/dev Redis runs without AUTH
REDIS_PASSWORD=CHANGE_ME

# ── MinIO ─────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=CHANGE_ME

# ── LLM API keys ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
OPENAI_API_KEY=sk-CHANGE_ME

# ── LiteLLM proxy (llm-gateway :7020) ─────────────────────────────────────────
LITELLM_MASTER_KEY=sk-theeyebeta-master-CHANGE_ME
LITELLM_DB_PASSWORD=CHANGE_ME
LITELLM_KEY_AGENT_RUNTIME_EXECUTORS=sk-litellm-CHANGE_ME
LITELLM_KEY_RND_AGENT=sk-litellm-CHANGE_ME
LITELLM_KEY_GUARD_SERVICE_CLASSIFIER=sk-litellm-CHANGE_ME
LITELLM_KEY_EMBEDDINGS=sk-litellm-CHANGE_ME

# ── Alpaca Markets (paper trading) ────────────────────────────────────────────
ALPACA_API_KEY_PAPER=CHANGE_ME
ALPACA_API_SECRET_PAPER=CHANGE_ME

# ── JWT (RS256 — paste PEM, use \n for line breaks) ───────────────────────────
# Generate: openssl genrsa -out /tmp/jwt.pem 4096
#           openssl rsa -in /tmp/jwt.pem -pubout -out /tmp/jwt.pub.pem
JWT_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nCHANGE_ME\n-----END RSA PRIVATE KEY-----
JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nCHANGE_ME\n-----END PUBLIC KEY-----

# ── Admin service ─────────────────────────────────────────────────────────────
ADMIN_USERNAME=admin
# Generate: python3 -c "import bcrypt; print(bcrypt.hashpw(b'yourpassword', bcrypt.gensalt()).decode())"
ADMIN_PASSWORD_BCRYPT=$2b$12$CHANGE_ME
