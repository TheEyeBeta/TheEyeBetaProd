# theeyebeta — production secrets template (plaintext reference only)
#
# Do NOT commit filled values. Encrypt with sops into secrets/prod.enc.yaml:
#   cp secrets/prod.enc.yaml.template secrets/prod.enc.yaml.plain
#   # edit prod.enc.yaml.plain
#   sops --encrypt --input-type dotenv --output-type yaml \
#        secrets/prod.enc.yaml.plain > secrets/prod.enc.yaml
#   rm secrets/prod.enc.yaml.plain
#
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=CHANGE_ME

# ── LLM providers ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-CHANGE_ME
OPENAI_API_KEY=sk-CHANGE_ME

# ── LiteLLM proxy (llm-gateway :7020) ─────────────────────────────────────────
LITELLM_MASTER_KEY=sk-theeyebeta-master-CHANGE_ME
LITELLM_DB_PASSWORD=CHANGE_ME
# Generate after first deploy: python services/llm_gateway/scripts/provision_virtual_keys.py
LITELLM_KEY_AGENT_RUNTIME_EXECUTORS=sk-litellm-CHANGE_ME
LITELLM_KEY_RND_AGENT=sk-litellm-CHANGE_ME
LITELLM_KEY_GUARD_SERVICE_CLASSIFIER=sk-litellm-CHANGE_ME
LITELLM_KEY_EMBEDDINGS=sk-litellm-CHANGE_ME
