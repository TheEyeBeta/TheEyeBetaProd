[Unit]
Description=theeyebeta Admin Service
After=network-online.target postgresql.service
Wants=network-online.target

[Service]
Type=simple
User=the-eye-beta
WorkingDirectory=/home/the-eye-beta/TheEyeBeta2025/TheEyeBetaProd
EnvironmentFile=-/home/the-eye-beta/TheEyeBeta2025/TheEyeBetaProd/.env.theeyebeta-admin
ExecStart=/home/the-eye-beta/.local/bin/uv --directory /home/the-eye-beta/TheEyeBeta2025/TheEyeBetaProd/services/admin_service run uvicorn main:app --host 0.0.0.0 --port 7200
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
