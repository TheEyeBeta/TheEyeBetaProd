[Unit]
Description=TheEyeBeta Supabase stock_snapshots sync (shadow mode default)
Wants=network-online.target
After=network-online.target postgresql.service

[Service]
Type=oneshot
User=the-eye-beta
Group=the-eye-beta
WorkingDirectory=/home/the-eye-beta/TheEyeBeta2025/TheEyeBetaProd
EnvironmentFile=-/home/the-eye-beta/TheEyeBeta2025/TheEyeBetaProd/.env.theeye-supabase-sync
ExecStart=/home/the-eye-beta/.local/bin/uv run python -m workers.supabase_sync_worker --shadow
TimeoutStartSec=1800

[Install]
WantedBy=multi-user.target
