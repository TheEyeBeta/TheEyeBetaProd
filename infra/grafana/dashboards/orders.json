            "type": "postgres",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "SELECT COALESCE(SUM(ABS(qty - filled_qty)), 0)::double precision AS reconciliation_drift FROM theeyebeta.orders WHERE status IN ('submitted','accepted','partially_filled')",
          "refId": "A"
        }
