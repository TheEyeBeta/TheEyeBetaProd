      "title": "Submission rate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "format": "time_series",
          "rawSql": "SELECT gs AS time, 'submitted' AS metric, COUNT(o.id)::double precision AS value FROM generate_series($__timeFrom()::timestamptz, $__timeTo()::timestamptz, interval '15 minutes') gs LEFT JOIN theeyebeta.orders o ON o.submitted_at >= gs AND o.submitted_at < gs + interval '15 minutes' GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ]
