      },
      "title": "Time to fill p50/p95",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "format": "time_series",
          "rawSql": "WITH fills AS (SELECT date_trunc('hour', updated_at) AS bucket, EXTRACT(EPOCH FROM (updated_at - submitted_at)) AS seconds FROM theeyebeta.orders WHERE status = 'filled' AND submitted_at IS NOT NULL AND $__timeFilter(updated_at)) SELECT gs AS time, 'p50' AS metric, COALESCE(percentile_cont(0.50) WITHIN GROUP (ORDER BY seconds), 0)::double precision AS value FROM generate_series($__timeFrom()::timestamptz, $__timeTo()::timestamptz, interval '1 hour') gs LEFT JOIN fills ON fills.bucket = gs GROUP BY 1 UNION ALL SELECT gs AS time, 'p95' AS metric, COALESCE(percentile_cont(0.95) WITHIN GROUP (ORDER BY seconds), 0)::double precision AS value FROM generate_series($__timeFrom()::timestamptz, $__timeTo()::timestamptz, interval '1 hour') gs LEFT JOIN fills ON fills.bucket = gs GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ]
    },
