      "title": "LLM cost daily",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "format": "time_series",
          "rawSql": "SELECT gs::timestamptz AS time, 'daily' AS metric, COALESCE(SUM(m.cost_usd), 0)::double precision AS value FROM generate_series(date_trunc('day', $__timeFrom()::timestamptz), date_trunc('day', $__timeTo()::timestamptz), interval '1 day') gs LEFT JOIN theeyebeta.model_runs m ON date_trunc('day', m.created_at) = gs GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "currencyUSD"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "title": "Cost by agent",
      "type": "barchart",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "WITH agent_costs AS (SELECT COALESCE(a.agent_id, 'unlinked') AS agent, SUM(m.cost_usd)::double precision AS cost_usd FROM theeyebeta.model_runs m LEFT JOIN theeyebeta.agent_runs a ON a.id = m.run_id WHERE $__timeFilter(m.created_at) GROUP BY 1) SELECT agent, cost_usd FROM agent_costs UNION ALL SELECT 'none' AS agent, 0::double precision AS cost_usd WHERE NOT EXISTS (SELECT 1 FROM agent_costs) ORDER BY cost_usd DESC",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "fieldConfig": {
