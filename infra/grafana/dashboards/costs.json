          "placement": "bottom"
        }
      },
      "title": "Cost by model",
      "type": "barchart",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "WITH model_costs AS (SELECT model, SUM(cost_usd)::double precision AS cost_usd FROM theeyebeta.model_runs WHERE $__timeFilter(created_at) GROUP BY model) SELECT model, cost_usd FROM model_costs UNION ALL SELECT 'none' AS model, 0::double precision AS cost_usd WHERE NOT EXISTS (SELECT 1 FROM model_costs) ORDER BY cost_usd DESC",
          "refId": "A"
        }
      ]
    },
