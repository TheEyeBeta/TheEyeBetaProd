      },
      "title": "Cumulative MTD",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "format": "time_series",
          "rawSql": "WITH days AS (SELECT generate_series(date_trunc('month', now())::date, current_date, interval '1 day')::date AS day), daily AS (SELECT created_at::date AS day, SUM(cost_usd) AS cost FROM theeyebeta.model_runs WHERE created_at >= date_trunc('month', now()) GROUP BY 1) SELECT day::timestamptz AS time, 'mtd' AS metric, SUM(COALESCE(cost,0)) OVER (ORDER BY day)::double precision AS value FROM days LEFT JOIN daily USING(day) ORDER BY day",
          "refId": "A"
        }
      ]
    }
