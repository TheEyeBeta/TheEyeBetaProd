          "format": "table",
          "rawSql": "SELECT COALESCE(SUM(COALESCE(unrealized_pnl,0) + COALESCE(realized_pnl,0)), 0)::double precision AS portfolio_pl FROM theeyebeta.positions",
          "refId": "A"
        }
