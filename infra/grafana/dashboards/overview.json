      },
      "title": "Today's pending orders",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "SELECT COUNT(*)::double precision AS pending_orders FROM theeyebeta.orders WHERE status = 'pending_approval' AND created_at >= date_trunc('day', now())",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "postgres"
      },
      "fieldConfig": {
