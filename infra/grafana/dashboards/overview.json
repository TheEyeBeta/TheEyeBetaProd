      },
      "gridPos": {
        "h": 5,
        "w": 4,
        "x": 12,
        "y": 0
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "value_and_name"
      },
      "title": "Today's LLM cost",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "SELECT COALESCE(SUM(cost_usd), 0)::double precision AS llm_cost_usd FROM theeyebeta.model_runs WHERE created_at >= date_trunc('day', now())",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
