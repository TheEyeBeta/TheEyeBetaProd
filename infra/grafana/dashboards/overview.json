      "title": "Last audit verify status",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "SELECT CASE WHEN COALESCE(MAX(created_at), 'epoch'::timestamptz) < now() - interval '24 hours' THEN 1 ELSE 0 END AS audit_verify_status FROM theeyebeta.audit_checkpoints",
          "refId": "A"
        }
      ]
    },
