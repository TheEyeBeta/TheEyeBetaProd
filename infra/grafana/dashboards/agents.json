      "id": 5,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "title": "Cost per hour",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "format": "time_series",
          "rawSql": "SELECT gs AS time, COALESCE(a.agent_id, 'none') AS metric, COALESCE(SUM(m.cost_usd), 0)::double precision AS value FROM generate_series($__timeFrom()::timestamptz, $__timeTo()::timestamptz, interval '1 hour') gs LEFT JOIN theeyebeta.agent_runs a ON date_trunc('hour', a.started_at) = gs LEFT JOIN theeyebeta.model_runs m ON m.run_id = a.id GROUP BY 1, 2 ORDER BY 1",
          "refId": "A"
        }
      ]
    },
