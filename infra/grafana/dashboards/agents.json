          "placement": "bottom"
        }
      },
      "title": "Guard violations per hour",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "format": "time_series",
          "rawSql": "SELECT gs AS time, COALESCE(g.agent_id, 'none') AS metric, COUNT(g.id)::double precision AS value FROM generate_series($__timeFrom()::timestamptz, $__timeTo()::timestamptz, interval '1 hour') gs LEFT JOIN theeyebeta.guard_violations g ON date_trunc('hour', g.ts) = gs GROUP BY 1, 2 ORDER BY 1",
          "refId": "A"
        }
      ]
    }
  ],
