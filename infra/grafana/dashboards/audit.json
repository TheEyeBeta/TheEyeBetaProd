      "title": "Checkpoint export age",
      "type": "stat",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "SELECT COALESCE(EXTRACT(EPOCH FROM (now() - MAX(created_at))), 999999)::double precision AS checkpoint_export_age_seconds FROM theeyebeta.audit_checkpoints",
          "refId": "A"
        }
