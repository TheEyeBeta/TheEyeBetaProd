      "title": "Guard violations by severity",
      "type": "barchart",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "format": "table",
          "rawSql": "WITH severities(severity) AS (VALUES ('low'), ('medium'), ('high'), ('critical')) SELECT s.severity, COUNT(g.id)::double precision AS violations FROM severities s LEFT JOIN theeyebeta.guard_violations g ON g.severity = s.severity AND $__timeFilter(g.ts) GROUP BY s.severity ORDER BY violations DESC",
          "refId": "A"
        }
      ]
