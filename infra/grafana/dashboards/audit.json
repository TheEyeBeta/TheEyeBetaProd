      "title": "Audit log row rate",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "postgres"
          },
          "format": "time_series",
          "rawSql": "SELECT gs AS time, 'audit rows' AS metric, COUNT(a.id)::double precision AS value FROM generate_series($__timeFrom()::timestamptz, $__timeTo()::timestamptz, interval '15 minutes') gs LEFT JOIN theeyebeta.audit_log a ON a.ts >= gs AND a.ts < gs + interval '15 minutes' GROUP BY 1 ORDER BY 1",
          "refId": "A"
        }
      ]
    },
