{
	debug
	cert_lifetime 12h
	renewal_window_ratio 0.25

	pki {
		ca local {
			name "TheEyeBeta Internal CA"
			root_cn "TheEyeBeta Internal Root CA"
			intermediate_cn "TheEyeBeta Internal Intermediate CA"
			intermediate_lifetime 24h
			maintenance_interval 10m
		}
	}
}

(theeyebeta_mtls) {
	tls {
		issuer internal {
			ca local
			lifetime 12h
		}
		client_auth {
			mode require_and_verify
			trust_pool pki_root {
				authority local
			}
		}
	}
}

data-ingestion.theeyebeta.internal {
	import theeyebeta_mtls
	reverse_proxy 127.0.0.1:7010
}

